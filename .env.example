# Copy this to .env.test and fill in for `pnpm test:e2e`.
# Both .env and .env.* are gitignored — this template is the only one tracked.

# --- Claude (one of these is required for Claude e2e tests) ---
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Codex (opt-in, also requires `codex login` or OPENAI_API_KEY) ---
# AGENT_SDK_CODEX_E2E=1
# OPENAI_API_KEY=sk-...
